<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (dark). -->
    <style name="Base.Theme.Garden" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color – slightly lighter for dark surfaces -->
        <item name="colorPrimary">@color/garden_green_light</item>
        <item name="colorOnPrimary">@color/garden_green_dark</item>
        <item name="colorPrimaryContainer">@color/garden_green_dark</item>
        <item name="colorOnPrimaryContainer">@color/garden_green_container</item>

        <!-- Secondary / accent -->
        <item name="colorSecondary">@color/garden_green_light</item>
        <item name="colorOnSecondary">@color/garden_green_dark</item>
        <item name="colorSecondaryContainer">@color/garden_green_dark</item>
        <item name="colorOnSecondaryContainer">@color/garden_green_container</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/garden_green_dark</item>

        <!-- Error -->
        <item name="colorError">@color/error_dark</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container_dark</item>
        <item name="colorOnErrorContainer">@color/on_error_container_dark</item>

        <!-- Surfaces / Backgrounds -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline_dark</item>
        <item name="colorOutlineVariant">@color/outline_variant_dark</item>

        <!-- Component styles inherit from light theme -->
        <item name="actionBarSize">@dimen/toolbar_height</item>
        <item name="materialButtonStyle">@style/Widget.Garden.Button</item>
        <item name="materialCardViewStyle">@style/Widget.Garden.CardView</item>
        <item name="textInputStyle">@style/Widget.Garden.TextInputLayout</item>
    </style>
</resources>