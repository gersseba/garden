<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (light). -->
    <style name="Base.Theme.Garden" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/garden_green</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/garden_green_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary / accent -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorSecondaryContainer">@color/garden_green_container</item>
        <item name="colorOnSecondaryContainer">@color/on_primary_container</item>

        <!-- Tertiary (same family for now) -->
        <item name="colorTertiary">@color/accent_dark</item>
        <item name="colorOnTertiary">@color/on_primary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <!-- Surfaces / Backgrounds -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Toolbar / ActionBar -->
        <item name="actionBarSize">@dimen/toolbar_height</item>
        <item name="materialButtonStyle">@style/Widget.Garden.Button</item>
        <item name="materialCardViewStyle">@style/Widget.Garden.CardView</item>
        <item name="textInputStyle">@style/Widget.Garden.TextInputLayout</item>
    </style>

    <style name="Theme.Garden" parent="Base.Theme.Garden" />
</resources>