# local.properties.example
# Copy this file to local.properties and fill in your values.
# NEVER commit local.properties — it is listed in .gitignore.

# Gemini API Key
# Obtain your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Android SDK location (set automatically by Android Studio)
# sdk.dir=/path/to/Android/Sdk
